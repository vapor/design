    <div class="row">
        <div class="col-lg-3">
            <div class="blog-tag-list">
                <h5 class="list-heading d-none d-lg-block">Blog Tags</h5>
                <button class="d-lg-none vapor-molecule vapor-molecule-list" id="tag-list-mobile-button" type="button" data-bs-toggle="collapse" data-bs-target="#tagListCollapse" aria-expanded="false" aria-controls="tagListCollapse"><div class="d-flex flex-row align-items-center">View All<span class="ms-auto vapor-icon icon-chevron-down"></span></div></button>
                <ul class="collapse tag-list-collapse mobile-drop-down-menu" id="tagListCollapse">
                    <li class="tag-list-tag"><a href="#" class="tag-link d-flex align-items-center active">View All<span class="badge ms-2 d-none d-lg-block">72</span></a></li>
                    <li class="tag-list-tag"><a href="#" class="tag-link d-flex align-items-center">Vapor<span class="badge ms-2 d-none d-lg-block">2</span></a></li>
                    <li class="tag-list-tag"><a href="#" class="tag-link d-flex align-items-center">Swift<span class="badge ms-2 d-none d-lg-block">2</span></a></li>
                    <li class="tag-list-tag"><a href="#" class="tag-link d-flex align-items-center">DevOps<span class="badge ms-2 d-none d-lg-block">2</span></a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

